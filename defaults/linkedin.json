{
  "name": "LinkedIn",
  "pattern": "^https://([^/]+\\.)?linkedin\\.com/",
  "cleanupSelectors": [
    "nav",
    "header",
    "footer",
    "aside",
    "[role='banner']",
    "[role='navigation']",
    "[role='contentinfo']",
    "[role='complementary']",
    "[role='dialog']",
    "[role='search']",
    "script",
    "style",
    "noscript",
    ".global-nav",
    "#global-nav",
    ".global-footer",
    ".scaffold-layout__aside",
    ".scaffold-layout__sticky-sidebar",
    ".scaffold-layout__sticky-content",
    ".msg-overlay-list-bubble",
    ".msg-overlay-bubble-header",
    ".msg-overlay-conversation-bubble",
    ".feed-shared-update-v2",
    ".feed-shared-mini-update-v2",
    ".feed-identity-module",
    ".share-box-feed-entry__top-bar",
    "[aria-label*='Promoted' i]",
    "[data-test-id*='ad' i]",
    "[id*='consent' i]",
    "[class*='cookie-banner' i]",
    "[data-section='activity']",
    "[data-view-name='profile-card-activity']",
    "section[aria-label*='Activity' i]",
    "section[aria-labelledby*='activity' i]",
    "#activity",
    "#content_collections",
    "[data-section='interests']",
    "[data-view-name='profile-card-interests']",
    "section[aria-label*='Interests' i]",
    "section[aria-labelledby*='interests' i]",
    "#interests",
    "video",
    "audio",
    ".video-js",
    ".vjs-control-bar",
    "[class^='vjs-']",
    ".pv-text-details__separator",
    ".pv-contact-info",
    ".distance-badge",
    "button[aria-label*='Message' i]",
    "button[aria-label*='Follow' i]",
    "button[aria-label*='Connect' i]",
    "button[aria-label*='Endorse' i]",
    "button[aria-label*='More actions' i]",
    "button[aria-label*='Save' i]",
    "a[href$='/recent-activity/all/']",
    "a[href*='/details/skills']",
    "a[href*='/details/interests']",
    "a[href*='/details/recent-activity']",
    "a[href*='/skill-insights/']",
    "a[href*='/endorsers/']",
    "a[href*='skill-associations-details']",
    "a[href*='/overlay/']",
    "a[href*='/messaging/compose']",
    "a[href*='/messaging/thread']",
    "a[data-control-name*='contact' i]",
    "button[data-control-name*='contact' i]",
    "[data-test-id*='contact-info']",
    "[id*='contact-info']",
    "a[href*='MEMBER_PROFILE_CANNED_SEARCH']",
    "[class*='lemlist' i]",
    "[id*='lemlist' i]",
    "[data-lemlist]",
    "[class*='lml-' i]"
  ],
  "removeSectionsByHeading": ["Activity", "Interests"]
}
